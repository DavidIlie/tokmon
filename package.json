{
  "name": "tokmon",
  "version": "0.14.5",
  "description": "Terminal dashboard for Claude Code, Codex, and Cursor usage, limits, and costs",
  "type": "module",
  "bin": {
    "tokmon": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run build:cli && pnpm run build:web",
    "build:cli": "tsup",
    "build:web": "pnpm --prefix web run build",
    "web:install": "pnpm --prefix web install",
    "dev": "tsx src/cli.tsx",
    "dev:web": "pnpm --prefix web run dev",
    "prepublishOnly": "pnpm run web:install && pnpm run build"
  },
  "dependencies": {
    "@zenobius/ink-mouse": "^1.0.3",
    "ink": "^5.0.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^18.0.0",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "author": "David Ilie <david@davidilie.com> (https://davidilie.com)",
  "homepage": "https://github.com/DavidIlie/tokmon",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavidIlie/tokmon.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "cursor",
    "usage",
    "tokens",
    "cost",
    "rate-limits",
    "terminal",
    "dashboard",
    "cli"
  ],
  "license": "MIT"
}
